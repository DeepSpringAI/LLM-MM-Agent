# MM-Agent runtime configuration (agent side)
# The agent is pure OpenAI-compatible and expects a standard /v1 endpoint.

# Point to local middleware
OPENAI_API_BASE=http://127.0.0.1:4010/v1

# Runtime behavior
LLM_TIMEOUT_SECONDS=120
LLM_DEBUG=true
LLM_STREAM=true
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=2.0
LLM_MAX_RATE_LIMIT_WAIT_SECONDS=300
LLM_MIN_RETRY_SLEEP_SECONDS=5.0
LLM_RATE_LIMIT_RESET_BUFFER_SECONDS=1.0
LLM_RATE_LIMIT_FALLBACK_SLEEP_SECONDS=30.0

# Method retrieval (HMML)
# If your middleware key cannot access an embeddings model, set LLM_ENABLE_EMBEDDINGS=false.
LLM_ENABLE_EMBEDDINGS=true
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_RETRIEVAL_METHOD=embedding

# Optional proxy for agent process egress
LLM_PROXY_URL=

# Optional API key variable if you prefer env-based key injection in your own wrappers
# OPENAI_API_KEY=
